{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/dashboard", "destination": "/dashboard_cliente.html" },
    { "source": "/staff", "destination": "/dashboard_staff.html" },
    { "source": "/calendario", "destination": "/calendario.html" },
    { "source": "/mis-clases", "destination": "/mis-clases.html" },
    { "source": "/bono", "destination": "/bono.html" },
    { "source": "/notificaciones", "destination": "/notificaciones.html" },
    { "source": "/perfil", "destination": "/perfil.html" }
  ],
  "headers": [
    {
      "source": "/supabase.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/login.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/dashboard_staff.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
