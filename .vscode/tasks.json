{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local server (Node 8080)",
      "type": "shell",
      "command": "npx --yes serve . -l 8080",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Accepting connections.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
